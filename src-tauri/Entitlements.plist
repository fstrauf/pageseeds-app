<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required by WebKit/Tauri webview -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required to load Tauri bundled libraries -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Outbound HTTP: updater, LLM APIs, GSC, Ahrefs, Reddit -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- File picker dialogs (user-selected files) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Access to user's repo directories for content/config reading/writing -->
  <key>com.apple.security.files.all</key>
  <true/>
</dict>
</plist>
