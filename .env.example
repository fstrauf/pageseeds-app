# PageSeeds Desktop — Build Environment
# Copy to .env and fill in values. NEVER commit .env.

# Tauri update artifact signing
# Generate keypair once with: pnpm tauri signer generate -w ~/.tauri/pageseeds.key
# Then paste the public key output into the "pubkey" field in src-tauri/tauri.conf.json
TAURI_SIGNING_PRIVATE_KEY_PATH=~/.tauri/pageseeds.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=your_key_password_here

# Apple notarization credentials
# Set up via: xcrun notarytool store-credentials
# These are only needed when Tauri is configured to auto-submit for notarization.
# The signing identity in tauri.conf.json uses the keychain certificate directly.
APPLE_ID=your@apple.id
APPLE_PASSWORD=app-specific-password-from-appleid.apple.com
APPLE_TEAM_ID=KMJ36PKPW8
